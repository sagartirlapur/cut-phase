  const pct=last?Math.min(100,Math.max(0,Math.round((84.5-last)/(84.5-80)*100))):0;
  const pts=wts.slice(-10);let ch='';
  if(pts.length>=2){const vals=pts.map(w=>w.w),mn=Math.min(...vals)-.5,mx=Math.max(...vals)+.5,rng=mx-mn||1,W=300,H=60;const cp=vals.map((v,i)=>`${i/(vals.length-1)*(W-20)+10},${H-((v-mn)/rng*(H-14)+7)}`).join(' ');ch=`<svg width="100%" viewBox="0 0 ${W} ${H}" style="overflow:visible;margin-top:10px"><polyline points="${cp}" fill="none" stroke="var(--ac)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>${vals.map((v,i)=>{const x=i/(vals.length-1)*(W-20)+10,y=H-((v-mn)/rng*(H-14)+7);return`<circle cx="${x}" cy="${y}" r="3.5" fill="var(--ac)"/><text x="${x}" y="${y-9}" text-anchor="middle" font-size="9" fill="var(--t2)">${v}</text>`;}).join('')}</svg>`;}
  const cO=coW!==null?coW:autoW;
  const logH=wts.slice().reverse().slice(0,10).map((e,i,arr)=>{const pv=arr[i+1],d=pv?+(e.w-pv.w).toFixed(1):null,dc=d===null?'transparent':d<0?'var(--gr)':'var(--ac)';return`<div style="display:flex;align-items:center;gap:8px;padding:8px 0;border-bottom:${i<Math.min(wts.length,10)-1?'1px solid var(--l1)':'none'}"><span style="font-size:11px;color:var(--t2);font-family:monospace;flex:1">${e.date}</span><span style="font-size:13px;font-weight:600;color:var(--t1);font-family:monospace">${e.w} kg</span><span style="font-size:11px;font-family:monospace;min-width:52px;text-align:right;color:${dc}">${d===null?'':(d<0?d:'+'+d)+' kg'}</span><button onclick="dWt('${e.date}')" style="background:none;border:none;color:var(--t2);cursor:pointer;font-size:13px;padding:0 0 0 6px">✕</button></div>`;}).join('');
  document.getElementById('t-progress').innerHTML=`<div class="sh">Progress</div><div class="ss">Log every Monday morning — same time, before eating.</div><div class="card"><div style="display:flex;justify-content:space-between;align-items:flex-start;margin-bottom:14px"><div><div style="font-size:36px;font-weight:700;color:var(--t1);font-family:monospace;letter-spacing:-1px">${last||'—'} <span style="font-size:16px;color:var(--t2)">kg</span></div><div style="font-size:11px;color:var(--t2);font-family:monospace;margin-top:3px">Goal: 80 kg · Start: 84.5 kg</div><div style="font-size:12px;font-weight:600;margin-top:4px;color:${tcol}">${ttxt}</div></div><div style="text-align:right"><div style="font-size:32px;font-weight:700;color:var(--ac);font-family:monospace;letter-spacing:-1px">${pct}%</div><div style="font-size:10px;color:var(--t2);margin-top:2px">to goal</div></div></div><div class="pb"><div class="pbf" style="width:${pct}%;background:var(--gr)"></div></div>${ch}</div><div class="card"><div class="ct">Log this week's weight</div><div style="display:flex;gap:8px;margin-bottom:10px"><input class="w-inp" type="number" id="wi" placeholder="e.g. 83.5" step="0.1" min="50" max="150"><button class="w-sav" onclick="sWt()">Save</button></div><div style="font-size:11px;color:var(--t2);font-family:monospace">Monday morning · before eating · after bathroom</div></div>${wts.length>0?`<div class="card"><div class="ct">History</div>${logH}</div>`:''}<div style="height:1px;background:var(--l1);margin:16px 0"></div><div class="card"><div class="ct">Cycle week override</div><div style="font-size:13px;color:var(--t2);margin-bottom:12px;line-height:1.5">Auto: Week ${autoW+1}.</div><div style="display:grid;grid-template-columns:repeat(4,1fr);gap:6px;margin-bottom:10px">${[0,1,2,3].map(i=>`<button class="cwb ${cO===i?'on':''}" onclick="sCO(${i})">Week ${i+1}</button>`).join('')}</div><button onclick="sCO(null)" style="font-size:11px;color:var(--t3);background:none;border:none;cursor:pointer;font-family:monospace;text-decoration:underline;padding:0">Reset to auto</button></div>`;
}
function sWt(){const v=parseFloat(document.getElementById('wi').value);if(isNaN(v)||v<50||v>150)return;const date=now.toLocaleDateString('en-GB',{day:'numeric',month:'short'});const ex=wts.findIndex(e=>e.date===date);if(ex>=0)wts[ex].w=v;else wts.push({date,w:v});ss('cp_wl',wts);rProgress();}
function dWt(date){wts=wts.filter(e=>e.date!==date);ss('cp_wl',wts);rProgress();}
function sCO(v){coW=v;ss('cp_co',v);cW=v!==null?v:autoW;if(v!==null)gW=v;document.getElementById('ci').textContent=`Day ${Math.max(1,diff+1)} · ${WEEKS[cW].n}`;rProgress();rToday();rPlan();rGrocery();}

function rDaily(){
  const tot=NN.length,dn2=Object.values(nnc).filter(Boolean).length,pct=Math.round(dn2/tot*100);
  const ml=cups*500,wpct=Math.min(100,Math.round(ml/3500*100));
  const cups_h=[1,2,3,4,5,6,7].map(i=>`<button class="wcup" onclick="tCup(${i})" style="border:${i<=cups?'none':'1.5px solid var(--l2)'};background:${i<=cups?'var(--bl)':'var(--s3)'}"><span style="font-size:9px;font-family:monospace;color:${i<=cups?'white':'var(--t2)'};font-weight:500">${i<=4?i*500+'ml':(i*.5).toFixed(1)+'L'}</span></button>`).join('');
  const nn_h=NN.map((item,i)=>{const ck=nnc[item.id]||false;return`<div class="nn-r" onclick="tNN('${item.id}')" style="${i===NN.length-1?'border-bottom:none':''}"><div class="cb ${ck?'on':''}" id="nn_${item.id}">${ck?CHK:''}</div><div style="flex:1"><div class="nn-l ${ck?'done':''}" id="nnl_${item.id}">${item.l}</div>${item.s?`<div class="nn-s">${item.s}</div>`:''}</div></div>`;}).join('');
  document.getElementById('t-daily').innerHTML=`<div class="sh">Daily checklist</div><div class="ss">Resets every morning. Build the habits, the results follow.</div><div class="card"><div class="ct">Water — target 3–3.5 L</div><div style="display:flex;gap:8px;margin-bottom:10px">${cups_h}</div><div class="pb" style="margin-bottom:8px"><div class="pbf" id="wpb" style="width:${wpct}%;background:var(--bl)"></div></div><div style="display:flex;justify-content:space-between;align-items:center"><span style="font-size:12px;color:var(--t2);font-family:monospace" id="wlbl">${ml}ml of 3,500ml</span><button onclick="rstW()" style="font-size:11px;color:var(--t3);background:none;border:none;cursor:pointer;font-family:monospace">Reset</button></div></div><div class="pb" style="margin-bottom:4px"><div class="pbf" id="nnpb" style="width:${pct}%;background:var(--ac)"></div></div><div style="display:flex;justify-content:space-between;font-size:11px;color:var(--t3);font-family:monospace;margin-bottom:12px"><span id="nnlbl">${dn2} of ${tot} done today</span><span>${pct}%</span></div><div class="card">${nn_h}</div><div class="info"><div class="it">Cut Phase Anchors</div><div class="ib">3.5L water · Walk after dinner · Sleep 7-8h · Magnesium glycinate at night · Flax in breakfast · Raw garlic at lunch</div></div>`;
}
function tCup(n){cups=cups===n?n-1:n;ss('cp_wc_'+now.toISOString().slice(0,10),cups);rDaily();}
function rstW(){cups=0;ss('cp_wc_'+now.toISOString().slice(0,10),0);rDaily();}
function tNN(id){nnc[id]=!nnc[id];ss('cp_nn_'+now.toISOString().slice(0,10),nnc);rDaily();}

document.querySelectorAll('.nb').forEach(btn=>{btn.addEventListener('click',()=>{document.querySelectorAll('.nb').forEach(b=>b.classList.remove('on'));btn.classList.add('on');document.querySelectorAll('.sec').forEach(s=>s.classList.remove('on'));document.getElementById('t-'+btn.dataset.t).classList.add('on');document.getElementById('scroll').scrollTo(0,0);if(btn.dataset.t==='progress')rProgress();if(btn.dataset.t==='train')rTrain();});});

rToday();rPlan();rGrocery();rDaily();rTrain();
</script>
</body>
</html>
